{
  "layer": "top",
  "position": "top",
  "margin-bottom": -10,
  "spacing": 0,

  "modules-left": [
    "custom/archicon",
    "hyprland/workspaces",
  ],

  "modules-center": [
  ],

  "modules-right": [
    "network",
    "cpu",
    "memory",
    "temperature",
    "backlight",
    "battery",
    "clock"
  ],

  "hyprland/workspaces": {
    "format": "{name}"
  },

  "bluetooth": {
    "format": "َ°‚²",
    "format-on": "{icon}",
    "format-off": "{icon}",
    "format-connected": "{icon}",
    "format-icons": {
      "on": "َ°‚¯",
      "off": "َ°‚²",
      "connected": "َ°‚±"
    },
    "on-click": "blueman-manager",
    "tooltip-format-connected": "{device_enumerate}"
  },

  "clock": {
    "timezone": "Asia/Yekaterinburg",
    "tooltip": false,
    "format": "{:%H:%M:%S  %d/%m/%Y}",
    "interval": 1
  },

  "network": {
    "format": "{ifname}",
    "format-wifi": "{ifname}: {ipaddr}/{cidr}",
    "format-ethernet": "{ipaddr}/{cidr}",
    "format-linked": "{ifname} (No IP)",
    "format-disconnected": "no connection",
    "format-alt": "{essid} ({signalStrength}%)",
    "interval": 5,
    "tooltip-format": "{ifname} via {gwaddr}",
    "on-click": ""
  },

  "cpu": {
    "interval": 2,
    "format": "CPU {usage:>2}%",
    "on-click": "foot -e htop"
  },

  "temperature": {
    // "thermal-zone": 2,
    // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    // "format-critical": "{temperatureC}آ°C {icon}",
    "format": "{temperatureC}آ°C",
    //"format-icons": ["ï‌«", "ï‹‰", "ï‌©"],
    "interval": "5"
    //"exec": "nvidia-smi --query-gpu=temperature.gpu"
  },

  "memory": {
    "interval": 30,
    "format": "MEM  {used:0.1f}G/{total:0.1f}G",
    "tooltip-format": "Memory"
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [ "îژچ", "َ°ƒœ", "َ°ƒ›", "َ°ƒ‍", "َ°ƒ‌", "َ°ƒں", "َ°ƒ " ],
    "interval": 2,
    "on-scroll-up": "brightnessctl set +1%",
    "on-scroll-down": "brightnessctl set 1%-",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "ï‘¦",
    "format-icons": {
      "default": [ "ï€¦", "ï€§", "ï€¨ " ]
    },
    "on-click": "pavucontrol"
  },

  "battery": {
    "interval": 10,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-full": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-plugged": "َ°‚„ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": [ "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ","َ°‚‚", "َ°پ¹" ] // nf-md-battery
  },

  "custom/lock": {
    "tooltip": false,
    "on-click": "sh -c '(sleep 0s; hyprlock)' & disown",
    "format": "ï€£"
  },

  "custom/archicon": {
    "format": "îœ²" // nf-dev-archlinux
  }
}
